# Copy to .env and fill in values before running
SECRET_KEY=change-this-secret-in-prod-must-be-32-chars-minimum
DATABASE_URL=sqlite+aiosqlite:///./solace.db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Optional overrides
# ENV=production
# RATE_LIMIT_PER_MINUTE=120
# DEFAULT_TENANT_ID=default

# Optional external API keys (leave blank to disable that integration)
# GITHUB_TOKEN=
# HIBP_API_KEY=
# ETHERSCAN_API_KEY=
# SHODAN_API_KEY=
# OLLAMA_HOST=http://localhost:11434

# MISP integration
# MISP_URL=https://your-misp-instance
# MISP_API_KEY=

# Slack integration
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_ALERTS_CHANNEL_ID=C0XXXXXXXX
